{
  "harnesses": ["claude", "codex", "opencode", "pi"],
  "lint": {
    "governedRoots": ["spec-dashboard/src", "spec-cli/src", "spec-forge/src", "spec-eval/src"],
    "sourceExtensions": ["ts", "tsx", "js", "jsx"],
    "scenarioTags": ["frontend-e2e", "backend-api", "cli", "desktop", "mobile"]
  },
  "doctor": {
    "altitude": { "lineBudget": 50, "charBudget": 4200, "sizeable": 35, "dense": 1.3, "steps": 3 },
    "breadth": { "maxChildren": 8 }
  },
  "dashboard": {
    "showHeadlessLaunchers": false
  },
  "sessions": {
    "maxActive": 8,
    "launchers": {
      "claude": { "harness": "claude", "cmd": "claude --dangerously-skip-permissions" },
      "claude-headless": { "harness": "claude-headless", "cmd": "claude --dangerously-skip-permissions" },
      "codex": { "harness": "codex", "cmd": "codex --yolo" },
      "pi": { "harness": "pi", "cmd": "pi" }
    },
    "defaultLauncher": "claude"
  }
}
