# dependencies & build output
node_modules
dist/
.vite/

# SpexCode worktrees live here — they are separate checkouts, never committed
.worktrees/

# per-worktree session runtime — EVERY harness-written artifact under ONE ignored dir (state, prompt,
# launch, hooks.json, launch.sh, claude.md), so the worktree's spec/code tree stays clean. (`.session` with
# no trailing slash also covers a legacy flat `.session` state file.) Removed with the worktree.
.session
# legacy flat runtime sidecars (pre runtime-dir refactor) — still ignored while in-flight sessions drain;
# remove these five lines once no flat-layout worktree remains.
.session-prompt
.session-launch
.spex-hooks.json
.spex-launch.sh
CLAUDE.spexhidden.md

# harness state
.claude/

# machine-local claude binary symlink (points into a per-machine install); the session
# launcher resolves `claude` from PATH (SPEXCODE_CLAUDE_CMD), so this is never vendored
spec-cli/bin/claude

# os / editor
.DS_Store
*.log
