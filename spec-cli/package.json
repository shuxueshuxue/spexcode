{
  "name": "@spexcode/spec-cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "SpexCode CLI + spec server — reads the .spec tree and its git history",
  "bin": { "spex": "bin/spex.mjs" },
  "scripts": {
    "dev": "tsx watch src/cli.ts serve",
    "serve": "tsx src/cli.ts serve",
    "lint": "tsx src/cli.ts lint",
    "postinstall": "node -e \"try{require('fs').readdirSync('node_modules/node-pty/prebuilds').forEach(d=>{try{require('fs').chmodSync('node_modules/node-pty/prebuilds/'+d+'/spawn-helper',0o755)}catch{}})}catch{}\""
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/node-ws": "^1.0.4",
    "hono": "^4.6.14",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
