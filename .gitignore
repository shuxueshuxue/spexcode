# dependencies & build output
node_modules
dist/
.vite/

# SpexCode worktrees live here — they are separate checkouts, never committed
.worktrees/

# per-worktree session linker — ephemeral runtime state, not spec data
.session
# originating-prompt sidecar (multi-line launch request) — runtime metadata, not spec data
.session-prompt
# per-worktree generated hook settings (writeSettings() writes absolute paths) — runtime, not spec data
.spex-hooks.json

# harness state
.claude/

# os / editor
.DS_Store
*.log
